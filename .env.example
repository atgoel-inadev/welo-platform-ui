# ── Local Development (defaults — works out of the box) ──────────────
VITE_AUTH_SERVICE_URL=http://localhost:3002/api/v1
VITE_TASK_MANAGEMENT_URL=http://localhost:3003/api/v1
VITE_PROJECT_MANAGEMENT_URL=http://localhost:3004/api/v1
VITE_WORKFLOW_ENGINE_URL=http://localhost:3001/api/v1
VITE_ANNOTATION_QA_URL=http://localhost:3005/api/v1

# ── Via Nginx Gateway + Cloudflare Tunnel (Netlify deployment) ────────
# The Nginx API gateway (port 80) routes all services via path prefixes.
# The Cloudflare Quick Tunnel exposes port 80 to the internet for free.
#
# Steps:
#   1. docker-compose up -d
#   2. docker-compose logs cloudflared | grep trycloudflare
#   3. Copy the tunnel URL (e.g. https://xyz.trycloudflare.com)
#   4. Set the 5 variables below in Netlify: Site → Environment variables
#   5. Trigger a new Netlify deploy (env vars are embedded at build time)
#
# VITE_AUTH_SERVICE_URL=https://TUNNEL_URL/auth/api/v1
# VITE_TASK_MANAGEMENT_URL=https://TUNNEL_URL/tasks/api/v1
# VITE_PROJECT_MANAGEMENT_URL=https://TUNNEL_URL/projects/api/v1
# VITE_WORKFLOW_ENGINE_URL=https://TUNNEL_URL/workflows/api/v1
# VITE_ANNOTATION_QA_URL=https://TUNNEL_URL/annotation-qa/api/v1
